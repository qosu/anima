# Anima — environment configuration
# Copy to .env and fill in real values.
# In production (systemd), sensitive secrets are injected via LoadCredential=
# (see /etc/systemd/system/anima.service.d/10-credentials.conf).

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8002
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000
WORKSPACES_ROOT=/root/rawos/workspaces
DB_PATH=/root/rawos/data/rawos.db

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-generate-with-secrets.token_hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── LLM (NVIDIA NIM or compatible OpenAI-API endpoint) ───────────────────────
LLM_API_KEY=nvapi-your-key-here
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_AGENT_MODEL=mistralai/mistral-medium-3.5-128b
LLM_SUMMARIZER_MODEL=mistralai/mistral-medium-3.5-128b
LLM_FALLBACK_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1
LLM_TIMEOUT_S=30

# ── Hugging Face (embeddings model download) ──────────────────────────────────
HF_TOKEN=hf_your-token-here

# ── Sandbox ───────────────────────────────────────────────────────────────────
SANDBOX_DOCKER=false

# ── Stripe (optional — only needed for billing features) ──────────────────────
STRIPE_KEY=sk_live_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here
STRIPE_PRICE_PRO=price_your-pro-price-id
STRIPE_PRICE_ENTERPRISE=price_your-enterprise-price-id

# ── Telegram (optional — audit chain mirror + owner notifications) ────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_OWNER_CHAT_ID=0
TELEGRAM_OWNER_EMAIL=owner@example.com
